# ── Database ──────────────────────────────────────────────────────
# Local MySQL (your laptop):
# DATABASE_URL=mysql+pymysql://root:YOUR_PASSWORD@localhost:3306/excel_validation_db
#
# App Runner (SQLite, default — no setup needed):
# DATABASE_URL=sqlite:///./excel_validation.db
#
# App Runner with AWS RDS MySQL (persistent, recommended for production):
# DATABASE_URL=mysql+pymysql://user:password@your-rds-endpoint:3306/excel_validation_db
DATABASE_URL=sqlite:///./excel_validation.db

